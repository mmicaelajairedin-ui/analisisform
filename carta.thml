<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex">
<title>Carta de presentación — Micaela Jairedin</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
<style>
:root{
  --accent:#8E7676;--accent-dk:#6B5A5F;--accent-lt:#F5EFEF;--accent-md:#DDD0D0;
  --t1:#4A3F3F;--t2:#6B6060;--muted:#9E9696;
  --bg:#E2E2E2;--card:#fff;--border:#D1D1D1;
  --r:14px;--r-sm:8px;
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;font-family:'Open Sans',sans-serif;color:var(--t1);}
body{background:var(--bg);display:flex;flex-direction:column;}

/* TOOLBAR */
.toolbar{
  position:sticky;top:0;z-index:100;
  background:var(--card);border-bottom:1px solid var(--border);
  padding:10px 20px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;
  box-shadow:0 2px 12px rgba(0,0,0,.06);
}
.btn-back{display:flex;align-items:center;gap:6px;padding:7px 14px;font-size:11px;font-weight:700;font-family:'Montserrat',sans-serif;border-radius:var(--r-sm);cursor:pointer;border:1.5px solid var(--accent-md);background:var(--accent-lt);color:var(--accent);text-decoration:none;transition:all .15s;}
.btn-back:hover{background:var(--accent-md);}
.toolbar-brand{display:flex;align-items:center;gap:8px;}
.toolbar-brand img{width:28px;height:28px;border-radius:50%;object-fit:cover;border:1.5px solid var(--accent-md);}
.toolbar-brand-name{font-size:11px;font-weight:700;color:var(--t1);font-family:'Montserrat',sans-serif;}
.tb-sep{width:1px;height:22px;background:var(--border);flex-shrink:0;}
.tb-btn{padding:7px 14px;font-size:11px;font-weight:700;font-family:'Montserrat',sans-serif;border-radius:var(--r-sm);cursor:pointer;border:none;transition:all .15s;}
.tb-btn.ghost{background:var(--accent-lt);color:var(--accent);border:1.5px solid var(--accent-md);}
.tb-btn.ghost:hover{background:var(--accent-md);}
.tb-btn.primary{background:var(--accent);color:#fff;}
.tb-btn.primary:hover{background:var(--accent-dk);}
.tb-btn.editing{background:#5A8C6E;color:#fff;border-color:#5A8C6E;}
.save-st{font-size:10px;color:var(--muted);}
.ml-auto{margin-left:auto;}

/* WORKSPACE */
.workspace{flex:1;overflow-y:auto;padding:36px 40px 60px;display:flex;flex-direction:column;align-items:center;}
.workspace-top{width:210mm;display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.ws-lbl{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;font-family:'Montserrat',sans-serif;}

/* CARTA PAPER — A4 */
.carta-paper{
  background:var(--card);width:210mm;min-height:297mm;
  box-shadow:0 20px 60px rgba(0,0,0,.18),0 4px 16px rgba(0,0,0,.08);
  border-radius:3px;position:relative;overflow:hidden;
}

/* CARTA HEADER */
.carta-header{
  background:var(--accent);padding:28px 40px;
  display:flex;align-items:center;justify-content:space-between;
}
.carta-header-name{font-family:'Montserrat',sans-serif;font-size:22px;font-weight:800;color:#fff;line-height:1.2;}
.carta-header-role{font-size:11px;color:rgba(255,255,255,.75);margin-top:3px;letter-spacing:.06em;text-transform:uppercase;}
.carta-header-contact{text-align:right;font-size:11px;color:rgba(255,255,255,.75);line-height:1.8;}

/* CARTA BODY */
.carta-body{padding:36px 40px;}
.carta-date{font-size:12px;color:var(--muted);margin-bottom:24px;font-style:italic;}
.carta-empresa{font-size:13px;font-weight:700;color:var(--t1);margin-bottom:24px;}
.carta-text{
  font-size:13px;color:var(--t1);line-height:1.9;
  white-space:pre-wrap;word-break:break-word;
  min-height:400px;
  outline:none;
  border:none;
  width:100%;
  font-family:'Open Sans',sans-serif;
  background:transparent;
  resize:none;
}
.carta-text:focus{outline:2px solid var(--accent-lt);}
.carta-firma{margin-top:40px;padding-top:20px;border-top:1px solid var(--border);}
.carta-firma-name{font-size:14px;font-weight:800;color:var(--t1);font-family:'Montserrat',sans-serif;}
.carta-firma-role{font-size:11px;color:var(--muted);}
.carta-footer{
  position:absolute;bottom:0;left:0;right:0;
  padding:12px 40px;background:var(--accent-lt);border-top:1px solid var(--accent-md);
  display:flex;align-items:center;justify-content:space-between;
}
.carta-footer-brand{font-size:10px;font-weight:700;color:var(--accent);font-family:'Montserrat',sans-serif;}
.carta-footer-web{font-size:10px;color:var(--muted);}

/* Loading */
.loading-msg{text-align:center;padding:5rem;color:var(--muted);font-size:14px;}

@media print{
  .toolbar{display:none!important;}
  .workspace{padding:0!important;}
  .carta-paper{box-shadow:none!important;border-radius:0!important;width:100%!important;}
  body{background:#fff!important;}
}
</style>
</head>
<body>

<div class="toolbar">
  <a class="btn-back" id="back-btn" href="#">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
    Volver
  </a>
  <div class="tb-sep"></div>
  <div class="toolbar-brand">
    <img src="data:image/jpeg;base64," alt="Micaela">
    <span class="toolbar-brand-name">Carta de presentación</span>
  </div>
  <div class="tb-sep"></div>
  <button class="tb-btn ghost" id="edit-btn" onclick="toggleEdit()">&#9998; Editar</button>
  <span class="save-st" id="save-st"></span>
  <button class="tb-btn primary ml-auto" onclick="imprimir()">&#8595; Imprimir / PDF</button>
</div>

<div class="workspace">
  <div class="workspace-top">
    <div class="ws-lbl">Vista previa · A4</div>
    <div id="carta-status" style="font-size:10px;font-weight:700;color:var(--muted);font-family:'Montserrat',sans-serif;"></div>
  </div>
  <div class="carta-paper" id="carta-paper">
    <div class="loading-msg">Cargando carta...</div>
  </div>
</div>

<script>
var SB='https://ddxnrsnjdvtqhxunxnwj.supabase.co';
var KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRkeG5yc25qZHZ0cWh4dW54bndqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUxNDk5MzksImV4cCI6MjA5MDcyNTkzOX0.t82X1x-PDgFDGYhKC7YXoRKhga9I8Hjet60QUYvtZLU';
var BASE='https://mmicaelajairedin-ui.github.io/analisisform';

var _email=null,_cand=null,_editing=false,_saveT=null;

// Leer email
var _pp=new URLSearchParams(window.location.search);
var _urlEmail=_pp.get('email');
if(_urlEmail){ _email=_urlEmail; }
else{ var _uu=localStorage.getItem('mj_user');if(_uu){try{_email=JSON.parse(_uu).email;}catch(e){}} }

document.getElementById('back-btn').href=BASE+'/cliente.html'+((_email)?'?email='+encodeURIComponent(_email):'');

if(!_email){
  document.getElementById('carta-paper').innerHTML='<div class="loading-msg">&#128272; Sesion no encontrada. <a href="'+BASE+'/login.html" style="color:var(--accent);">Iniciar sesion</a></div>';
}else{
  cargarCarta();
}

function cargarCarta(){
  fetch(SB+'/rest/v1/candidatos?email=eq.'+encodeURIComponent(_email)+'&select=*&limit=1',{
    headers:{'apikey':KEY,'Authorization':'Bearer '+KEY}
  }).then(function(r){return r.json();}).then(function(rows){
    _cand=rows&&rows.length?rows[0]:null;
    renderCarta();
  }).catch(function(){
    document.getElementById('carta-paper').innerHTML='<div class="loading-msg">Error al cargar. Recarga la pagina.</div>';
  });
}

function esc(t){return(t||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

function renderCarta(){
  if(!_cand){ document.getElementById('carta-paper').innerHTML='<div class="loading-msg">No se encontraron datos.</div>'; return; }
  var c=_cand;
  var nombre=c.nombre||'Tu nombre';
  var email2=c.email||'';
  var tel=c.telefono||c.tel||'';
  var ciudad=c.ubicacion||c.ciudad||'';
  var carta=c.carta_presentacion||'';
  var hoy=new Date().toLocaleDateString('es-ES',{day:'numeric',month:'long',year:'numeric'});

  var html='';
  html+='<div class="carta-header">';
  html+='<div><div class="carta-header-name">'+esc(nombre)+'</div>';
  html+='<div class="carta-header-role">'+esc(c.sector||c.rol||'Profesional')+'</div></div>';
  html+='<div class="carta-header-contact">';
  if(email2) html+=esc(email2)+'<br>';
  if(tel) html+=esc(tel)+'<br>';
  if(ciudad) html+=esc(ciudad);
  html+='</div></div>';

  html+='<div class="carta-body">';
  html+='<div class="carta-date">'+hoy+'</div>';
  if(carta){
    // Extraer empresa/puesto si los tiene
    var firstLine=carta.split('\n')[0]||'';
    var esEncabezado=firstLine.toLowerCase().includes('estimad')||firstLine.toLowerCase().includes('a quien');
    if(esEncabezado){
      html+='<div class="carta-empresa">'+esc(firstLine)+'</div>';
      carta=carta.split('\n').slice(1).join('\n').trim();
    }
  }
  html+='<textarea class="carta-text" id="carta-ta" oninput="schedSave()">'+esc(carta||'Escribe tu carta de presentación aquí...\n\nRecuerda personalizar [EMPRESA] y [PUESTO] con los datos reales.')+'</textarea>';
  html+='<div class="carta-firma"><div class="carta-firma-name">'+esc(nombre)+'</div><div class="carta-firma-role">'+esc(c.sector||'')+'</div></div>';
  html+='</div>';

  html+='<div class="carta-footer">';
  html+='<div class="carta-footer-brand">Micaela Jairedin · Career Coach</div>';
  html+='<div class="carta-footer-web">mmicaelajairedin.com</div>';
  html+='</div>';

  document.getElementById('carta-paper').innerHTML=html;
  document.getElementById('carta-status').textContent=carta?'Carta cargada':'Sin carta aun';

  // Ajustar altura del textarea automáticamente
  var ta=document.getElementById('carta-ta');
  if(ta){
    ta.style.height='auto';
    ta.style.height=Math.max(ta.scrollHeight,400)+'px';
    ta.addEventListener('input',function(){
      ta.style.height='auto';
      ta.style.height=Math.max(ta.scrollHeight,400)+'px';
    });
    ta.readOnly=true;
  }
}

function toggleEdit(){
  _editing=!_editing;
  var btn=document.getElementById('edit-btn');
  var ta=document.getElementById('carta-ta');
  if(!ta) return;
  if(_editing){
    ta.readOnly=false;
    ta.focus();
    ta.style.background='#FAFAFA';
    ta.style.outline='2px solid var(--accent-lt)';
    if(btn){btn.textContent='&#10003; Listo';btn.classList.add('editing');btn.classList.remove('ghost');}
  }else{
    ta.readOnly=true;
    ta.style.background='transparent';
    ta.style.outline='none';
    if(btn){btn.innerHTML='&#9998; Editar';btn.classList.remove('editing');btn.classList.add('ghost');}
    guardarAhora();
  }
}

function schedSave(){
  clearTimeout(_saveT);
  var st=document.getElementById('save-st');
  if(st) st.textContent='Guardando...';
  _saveT=setTimeout(guardarAhora,2000);
}

function guardarAhora(){
  if(!_email) return;
  var ta=document.getElementById('carta-ta');
  if(!ta) return;
  var val=ta.value;
  var st=document.getElementById('save-st');
  fetch(SB+'/rest/v1/candidatos?email=eq.'+encodeURIComponent(_email),{
    method:'PATCH',
    headers:{'apikey':KEY,'Authorization':'Bearer '+KEY,'Content-Type':'application/json','Prefer':'return=minimal'},
    body:JSON.stringify({carta_presentacion:val})
  }).then(function(r){
    if(st){
      st.textContent=r.ok||r.status===204?'&#10003; Guardada':'Error';
      setTimeout(function(){if(st)st.textContent='';},2500);
    }
  }).catch(function(){if(st){st.textContent='Error';setTimeout(function(){st.textContent='';},2500);}});
}

function imprimir(){
  guardarAhora();
  setTimeout(function(){window.print();},400);
}
</script>
</body>
</html>
