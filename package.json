{
  "name": "analisisform-testing-agent",
  "version": "1.0.0",
  "description": "Agente de testing diario para la plataforma de mentoría de Micaela Jairedin",
  "private": true,
  "scripts": {
    "test": "npx playwright test",
    "test:report": "node tests/generate-report.js",
    "test:daily": "npx playwright test --reporter=json 2>/dev/null | node tests/generate-report.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
