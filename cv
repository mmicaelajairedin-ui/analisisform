<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CV Optimizado</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Montserrat',sans-serif;background:#f0ece8;min-height:100vh;padding:2rem 1rem 3rem;}

/* TOP BAR - ONLY SCREEN */
.top-bar{max-width:820px;margin:0 auto 1.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;}
.brand-pill{font-size:12px;font-weight:600;color:#8C7B80;background:#fff;padding:6px 16px;border-radius:20px;border:1px solid #e0d8d5;}
.actions{display:flex;gap:8px;}
.btn{padding:8px 20px;font-size:12px;font-weight:600;font-family:'Montserrat',sans-serif;border:none;border-radius:8px;cursor:pointer;transition:all .15s;}
.btn-primary{background:#8C7B80;color:#fff;}.btn-primary:hover{background:#6B5A5F;}
.btn-outline{background:#fff;color:#8C7B80;border:1.5px solid #8C7B80;}.btn-outline:hover{background:#f3efef;}

/* CODE ENTRY */
.code-screen{max-width:420px;margin:4rem auto;background:#fff;border-radius:16px;padding:2.5rem;text-align:center;}
.lock-icon{font-size:42px;margin-bottom:1rem;}
.code-screen h2{font-family:'Playfair Display',serif;font-size:22px;color:#1a1a1a;margin-bottom:8px;}
.code-screen p{font-size:13px;color:#666;line-height:1.6;margin-bottom:1.5rem;}
.code-input{width:150px;padding:12px;font-size:18px;font-family:'Montserrat',sans-serif;font-weight:700;letter-spacing:.3em;text-align:center;text-transform:uppercase;border:2px solid #ddd;border-radius:10px;outline:none;transition:border-color .15s;}
.code-input:focus{border-color:#8C7B80;}
.code-btn{margin-top:12px;width:100%;padding:12px;font-size:14px;font-weight:600;font-family:'Montserrat',sans-serif;background:#8C7B80;color:#fff;border:none;border-radius:10px;cursor:pointer;}
.code-btn:hover{background:#6B5A5F;}
.code-err{font-size:12px;color:#c0756e;margin-top:8px;min-height:16px;}

/* CV DOCUMENT */
.cv{max-width:820px;margin:0 auto;background:#fff;box-shadow:0 4px 40px rgba(0,0,0,.12);}

/* HEADER */
.cv-head{background:#8C7B80;padding:40px 44px;display:flex;gap:28px;align-items:center;}
.cv-photo{width:96px;height:96px;border-radius:50%;border:3px solid rgba(255,255,255,.35);flex-shrink:0;background:rgba(255,255,255,.18);display:flex;align-items:center;justify-content:center;overflow:hidden;}
.cv-photo img{width:100%;height:100%;object-fit:cover;border-radius:50%;}
.cv-photo-ini{font-family:'Playfair Display',serif;font-size:30px;color:rgba(255,255,255,.9);}
.cv-head-info{flex:1;}
.cv-name{font-family:'Playfair Display',serif;font-size:28px;color:#fff;line-height:1.15;margin-bottom:5px;}
.cv-role{font-size:12px;font-weight:600;color:rgba(255,255,255,.8);letter-spacing:.12em;text-transform:uppercase;margin-bottom:14px;}
.cv-contacts{display:flex;flex-wrap:wrap;gap:14px;}
.cv-contact{font-size:11px;color:rgba(255,255,255,.75);display:flex;align-items:center;gap:5px;}
.cv-contact strong{color:#fff;font-weight:600;}
.cv-badge{display:inline-block;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);color:#fff;font-size:10px;font-weight:600;padding:3px 10px;border-radius:20px;letter-spacing:.06em;margin-top:10px;}

/* BODY */
.cv-body{display:grid;grid-template-columns:220px 1fr;}

/* SIDEBAR */
.cv-side{background:#f9f7f6;padding:32px 24px;border-right:1px solid #ede8e5;}
.cv-sec{margin-bottom:28px;}
.cv-sec-title{font-size:9px;font-weight:700;color:#8C7B80;text-transform:uppercase;letter-spacing:.14em;margin-bottom:12px;padding-bottom:6px;border-bottom:2px solid #8C7B80;}
.skill-row{font-size:11.5px;color:#333;padding:4px 0;border-bottom:0.5px solid #ede8e5;line-height:1.4;}
.skill-row:last-child{border-bottom:none;}
.lang-row{display:flex;justify-content:space-between;align-items:baseline;padding:5px 0;border-bottom:0.5px solid #ede8e5;}
.lang-name{font-size:11.5px;color:#333;font-weight:500;}
.lang-lvl{font-size:10px;color:#8C7B80;font-weight:700;}
.edu-item{margin-bottom:12px;}
.edu-deg{font-size:11.5px;font-weight:700;color:#1a1a1a;line-height:1.3;}
.edu-inst{font-size:10.5px;color:#666;margin-top:1px;}
.edu-yr{font-size:10px;color:#8C7B80;font-weight:600;margin-top:2px;}
.cert-item{font-size:11px;color:#333;padding:4px 0;border-bottom:0.5px solid #ede8e5;line-height:1.4;}
.cert-item:last-child{border-bottom:none;}
.score-item{margin-bottom:10px;}
.score-lbl{font-size:10px;color:#555;margin-bottom:3px;font-weight:500;display:flex;justify-content:space-between;}
.score-pct{font-weight:700;color:#8C7B80;}
.score-track{height:4px;background:#e5e0de;border-radius:2px;overflow:hidden;}
.score-fill{height:4px;border-radius:2px;background:#8C7B80;}

/* MAIN */
.cv-main{padding:32px 36px;}
.sec{margin-bottom:26px;}
.sec-title{font-size:9px;font-weight:700;color:#8C7B80;text-transform:uppercase;letter-spacing:.14em;margin-bottom:12px;padding-bottom:6px;border-bottom:2px solid #8C7B80;}
.summary{font-size:12.5px;color:#333;line-height:1.8;}
.exp-item{margin-bottom:20px;padding-bottom:20px;border-bottom:0.5px solid #ede8e5;}
.exp-item:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0;}
.exp-head{display:flex;justify-content:space-between;align-items:flex-start;gap:10px;margin-bottom:3px;}
.exp-title{font-size:14px;font-weight:700;color:#1a1a1a;line-height:1.3;}
.exp-dates{font-size:10px;font-weight:700;color:#8C7B80;white-space:nowrap;flex-shrink:0;background:#f3efef;padding:2px 8px;border-radius:10px;}
.exp-company{font-size:11.5px;color:#666;font-style:italic;margin-bottom:6px;}
.exp-context{font-size:11px;color:#888;background:#f9f7f6;border-radius:4px;padding:5px 8px;margin-bottom:7px;line-height:1.5;border-left:2px solid #D4C5C8;}
.exp-bullets{list-style:none;padding:0;}
.exp-bullets li{font-size:12px;color:#333;line-height:1.7;padding:2px 0 2px 14px;position:relative;}
.exp-bullets li::before{content:'';position:absolute;left:0;top:9px;width:5px;height:5px;border-radius:50%;background:#8C7B80;}
.exp-bullets strong{font-weight:700;color:#1a1a1a;}

/* FOOTER */
.cv-foot{background:#f9f7f6;border-top:1px solid #ede8e5;padding:12px 44px;display:flex;justify-content:space-between;align-items:center;}
.cv-foot-brand{font-size:10px;font-weight:600;color:#8C7B80;}
.cv-foot-note{font-size:10px;color:#aaa;}

@media(max-width:640px){
  .cv-body{grid-template-columns:1fr;}
  .cv-side{border-right:none;border-bottom:1px solid #ede8e5;}
  .cv-head{flex-direction:column;text-align:center;}
  .cv-contacts{justify-content:center;}
}
@media print{
  body{background:#fff;padding:0;}
  .top-bar{display:none;}
  .cv{box-shadow:none;max-width:100%;}
  .cv-head{-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  .cv-side{-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  .score-fill{-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  @page{margin:.5cm;size:A4;}
}
</style>
</head>
<body>

<div class="top-bar" id="top-bar">
  <div class="brand-pill">Micaela Jairedin &middot; Career Coach & Recruiter</div>
  <div class="actions">
    <button class="btn btn-outline" onclick="abrirEditor()">Editar</button>
    <button class="btn btn-primary" onclick="window.print()">Descargar PDF</button>
  </div>
</div>

<div id="root"></div>

<script>
var SB='https://ddxnrsnjdvtqhxunxnwj.supabase.co';
var KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRkeG5yc25qZHZ0cWh4dW54bndqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUxNDk5MzksImV4cCI6MjA5MDcyNTkzOX0.t82X1x-PDgFDGYhKC7YXoRKhga9I8Hjet60QUYvtZLU';
var BASE='https://mmicaelajairedin-ui.github.io/analisisform';

var _row=null, _email=null, _code=null;

function init(){
  var p=new URLSearchParams(window.location.search);
  _email=p.get('email');
  _code=p.get('code');
  if(!_email){showErr('No se encontro el CV.');return;}
  fetchCV();
}

function fetchCV(){
  fetch(SB+'/rest/v1/cv_publicados?email=eq.'+encodeURIComponent(_email)+'&order=created_at.desc&limit=1&select=*',{
    headers:{'apikey':KEY,'Authorization':'Bearer '+KEY}
  }).then(function(r){return r.json();}).then(function(rows){
    if(!rows||!rows.length){showErr('Tu CV aun no esta disponible. Micaela lo publicara pronto.');return;}
    _row=rows[0];
    if(_row.codigo&&_code!==_row.codigo){
      showCodeForm();
    } else {
      renderCV(_row.contenido||'');
    }
  }).catch(function(){showErr('Error al cargar. Intentalo de nuevo.');});
}

function showErr(msg){
  document.getElementById('root').innerHTML='<div class="code-screen"><p style="color:#999;">'+msg+'</p><p style="font-size:11px;color:#ccc;margin-top:8px;">mmicaela.jairedin@gmail.com</p></div>';
}

function showCodeForm(){
  document.getElementById('root').innerHTML='<div class="code-screen">'
    +'<div class="lock-icon">&#128274;</div>'
    +'<h2>Introduce tu codigo</h2>'
    +'<p>Micaela te lo envio por WhatsApp junto con este link.</p>'
    +'<input class="code-input" id="code-inp" type="text" maxlength="6" placeholder="XXXXXX" autocomplete="off">'
    +'<button class="code-btn" onclick="verificar()">Acceder a mi CV</button>'
    +'<p class="code-err" id="code-err"></p>'
    +'</div>';
}

function verificar(){
  var code=document.getElementById('code-inp').value.trim().toUpperCase();
  if(!_row||!_row.codigo){document.getElementById('code-err').textContent='CV no disponible.';return;}
  if(code===_row.codigo.toUpperCase()){
    _code=code;
    window.history.replaceState({},'',location.pathname+'?email='+encodeURIComponent(_email)+'&code='+code);
    renderCV(_row.contenido||'');
  } else {
    document.getElementById('code-err').textContent='Codigo incorrecto. Verifica el mensaje de Micaela.';
  }
}

function parseCV(text){
  var lines=text.split('\n');
  var data={name:'',role:'',email:'',phone:'',city:'',linkedin:'',
    summary:'',skills:[],langs:[],edu:[],certs:[],exp:[],rawText:text};

  // Name: first non-empty line
  for(var i=0;i<Math.min(6,lines.length);i++){
    if(lines[i].trim()&&!lines[i].includes('@')&&!lines[i].match(/^\+?\d/)){
      data.name=lines[i].trim();break;
    }
  }
  // Role: second meaningful line
  for(var i=1;i<Math.min(10,lines.length);i++){
    var l=lines[i].trim();
    if(l&&l!==data.name&&l.length>8&&!l.includes('@')&&!l.match(/^\+?\d/)&&!l.includes('linkedin')){
      data.role=l;break;
    }
  }
  var em=text.match(/[\w.+-]+@[\w.-]+\.\w+/);if(em)data.email=em[0];
  var ph=text.match(/\+?[\d\s().-]{9,20}/);if(ph)data.phone=ph[0].trim();
  var li=text.match(/linkedin\.com\/in\/[\w-]+/i);if(li)data.linkedin=li[0];
  var ci=text.match(/(?:Boiro|Barcelona|Madrid|Valencia|Galicia|A Coru[nñ]a|Sevilla|Bilbao)[^|\n]*/i);if(ci)data.city=ci[0].trim().replace(/[·|,].*$/,'').trim();

  // Extract sections
  data.summaryText=extractSec(text,'RESUMEN');
  data.skillsText=extractSec(text,'HABILIDADES');
  data.langsText=extractSec(text,'IDIOMAS');
  data.eduText=extractSec(text,'FORMACI');
  data.certText=extractSec(text,'CERTIFICACI');
  data.expText=extractSec(text,'EXPERIENCIA');

  return data;
}

function extractSec(text,kw){
  var upper=text.toUpperCase();
  var idx=upper.indexOf(kw);
  if(idx===-1)return '';
  var after=text.substring(idx);
  var lines=after.split('\n');
  var out=[];
  for(var i=1;i<lines.length;i++){
    var l=lines[i];
    var u=l.trim().toUpperCase().replace(/[^A-Z\s]/g,'');
    if(u.length>4&&u.length<50&&u===l.trim().toUpperCase().replace(/[^A-Z\s]/g,'')&&l.trim().length>3&&i>0&&!l.trim().startsWith('-')&&!l.trim().startsWith('·')){
      if(out.length>0) break;
    }
    out.push(l);
  }
  return out.join('\n').trim();
}

function splitExp(text){
  if(!text) return [];
  var blocks=[];
  var cur=[];
  var lines=text.split('\n');
  lines.forEach(function(l){
    var hasDate=l.match(/\d{4}/);
    var isTitle=l.trim().length>5&&l.trim().length<100&&!l.trim().startsWith('-')&&!l.trim().startsWith('·');
    if(hasDate&&isTitle&&cur.length>2){
      blocks.push(cur.join('\n'));cur=[l];
    } else {cur.push(l);}
  });
  if(cur.length) blocks.push(cur.join('\n'));
  return blocks.filter(function(b){return b.trim().length>20;});
}

function renderExpBlock(block){
  var lines=block.split('\n').filter(function(l){return l.trim();});
  if(!lines.length) return '';
  var titleLine=lines[0];
  var dates='';var company='';var context='';var bullets=[];
  var dm=titleLine.match(/(\d{4})\s*[-\u2013\u2014]\s*([\w]+|\d{4})/);
  if(dm){dates=dm[0];titleLine=titleLine.replace(dm[0],'').replace(/[|·\-\u2014]/g,'').trim();}
  for(var i=1;i<lines.length;i++){
    var l=lines[i].trim();
    if(!l) continue;
    if(i===1&&!l.startsWith('-')&&!l.startsWith('·')&&!l.startsWith('•')){company=l;}
    else if(l.toLowerCase().includes('contexto:')||l.toLowerCase().includes('nota:')){context=l.replace(/^\*+/,'').replace(/contexto:|nota:/i,'').trim();}
    else if(l.startsWith('-')||l.startsWith('·')||l.startsWith('•')){
      bullets.push(l.replace(/^[-·•]\s*/,''));
    }
  }
  var html='<div class="exp-item">';
  html+='<div class="exp-head"><div class="exp-title">'+esc(titleLine)+'</div>'+(dates?'<div class="exp-dates">'+esc(dates)+'</div>':'')+'</div>';
  if(company) html+='<div class="exp-company">'+esc(company)+'</div>';
  if(context) html+='<div class="exp-context">'+esc(context)+'</div>';
  if(bullets.length){
    html+='<ul class="exp-bullets">';
    bullets.forEach(function(b){
      // Bold words in ALL CAPS or with ** markers
      var formatted=b.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>');
      html+='<li>'+formatted+'</li>';
    });
    html+='</ul>';
  }
  html+='</div>';
  return html;
}

function esc(t){return (t||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

function renderCV(text){
  var d=parseCV(text);
  var ini=d.name.split(' ').map(function(w){return w[0]||'';}).join('').slice(0,2).toUpperCase()||'CV';

  var skills=d.skillsText?d.skillsText.split('\n').filter(function(l){return l.trim()&&!l.match(/^[\-·•\s]*$/);}).map(function(l){return l.replace(/^[\-·•]\s*/,'').trim();}).filter(Boolean):[];
  var langs=d.langsText?d.langsText.split('\n').filter(function(l){return l.trim();}).map(function(l){
    var parts=l.split(':');
    return {name:(parts[0]||'').replace(/^[\-·•]\s*/,'').trim(),lvl:(parts[1]||'').trim()};
  }).filter(function(x){return x.name;}):[];
  var edus=d.eduText?d.eduText.split('\n').filter(function(l){return l.trim();}).map(function(l){
    var parts=l.replace(/^[\-·•]\s*/,'').split('·');
    return {deg:(parts[0]||'').trim(),inst:(parts[1]||'').trim(),yr:(parts[2]||parts[3]||'').trim()};
  }).filter(function(x){return x.deg.length>2;}):[];
  var certs=d.certText?d.certText.split('\n').filter(function(l){return l.trim()&&l.trim()!=='--';}).map(function(l){return l.replace(/^[\-·•]\s*/,'').trim();}):[];
  var expBlocks=splitExp(d.expText);

  var html='<div class="cv">';

  // HEADER
  html+='<div class="cv-head">'
    +'<div class="cv-photo"><div class="cv-photo-ini">'+ini+'</div></div>'
    +'<div class="cv-head-info">'
      +'<div class="cv-name" id="cv-name">'+esc(d.name||'Nombre del candidato')+'</div>'
      +'<div class="cv-role" id="cv-role">'+esc(d.role)+'</div>'
      +'<div class="cv-contacts">'
        +(d.email?'<div class="cv-contact"><strong>'+esc(d.email)+'</strong></div>':'')
        +(d.phone?'<div class="cv-contact">'+esc(d.phone)+'</div>':'')
        +(d.city?'<div class="cv-contact">'+esc(d.city)+'</div>':'')
        +(d.linkedin?'<div class="cv-contact">'+esc(d.linkedin)+'</div>':'')
      +'</div>'
      +'<div class="cv-badge">Disponibilidad inmediata &middot; Abierto a relocalizaci&oacute;n</div>'
    +'</div>'
  +'</div>';

  // BODY
  html+='<div class="cv-body">';

  // SIDEBAR
  html+='<div class="cv-side">';
  if(skills.length){
    html+='<div class="cv-sec"><div class="cv-sec-title">Habilidades</div>';
    skills.forEach(function(s){html+='<div class="skill-row">'+esc(s)+'</div>';});
    html+='</div>';
  }
  if(langs.length){
    html+='<div class="cv-sec"><div class="cv-sec-title">Idiomas</div>';
    langs.forEach(function(l){html+='<div class="lang-row"><span class="lang-name">'+esc(l.name)+'</span>'+(l.lvl?'<span class="lang-lvl">'+esc(l.lvl)+'</span>':'')+'</div>';});
    html+='</div>';
  }
  if(edus.length){
    html+='<div class="cv-sec"><div class="cv-sec-title">Formaci&oacute;n</div>';
    edus.forEach(function(e){
      html+='<div class="edu-item"><div class="edu-deg">'+esc(e.deg)+'</div>'
        +(e.inst?'<div class="edu-inst">'+esc(e.inst)+'</div>':'')
        +(e.yr?'<div class="edu-yr">'+esc(e.yr)+'</div>':'')
        +'</div>';
    });
    html+='</div>';
  }
  if(certs.length){
    html+='<div class="cv-sec"><div class="cv-sec-title">Certificaciones</div>';
    certs.forEach(function(c){html+='<div class="cert-item">'+esc(c)+'</div>';});
    html+='</div>';
  }
  html+='</div>'; // end sidebar

  // MAIN
  html+='<div class="cv-main">';
  if(d.summaryText){
    html+='<div class="sec"><div class="sec-title">Resumen ejecutivo</div>'
      +'<div class="summary">'+esc(d.summaryText)+'</div></div>';
  }
  if(expBlocks.length){
    html+='<div class="sec"><div class="sec-title">Experiencia profesional</div>';
    expBlocks.forEach(function(b){html+=renderExpBlock(b);});
    html+='</div>';
  }
  html+='</div>'; // end main
  html+='</div>'; // end body

  // FOOTER
  html+='<div class="cv-foot">'
    +'<div class="cv-foot-brand">Micaela Jairedin &middot; Career Coach & Recruiter</div>'
    +'<div class="cv-foot-note">CV optimizado &middot; Confidencial</div>'
    +'</div>';

  html+='</div>'; // end cv

  document.getElementById('root').innerHTML=html;
}

function abrirEditor(){
  // Simple inline edit: click on name/role to edit
  var name=document.getElementById('cv-name');
  var role=document.getElementById('cv-role');
  if(name) name.contentEditable='true';
  if(role) role.contentEditable='true';
  if(name) name.focus();
  var btn=document.querySelector('.btn-outline');
  if(btn){btn.textContent='Guardar';btn.onclick=function(){
    if(name) name.contentEditable='false';
    if(role) role.contentEditable='false';
    btn.textContent='Editar';btn.onclick=abrirEditor;
  };}
}

init();
</script>
</body>
</html>
