<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CV — Micaela Jairedin</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Montserrat',sans-serif;background:#f5f5f3;color:#1a1a1a;padding:2rem 1rem;}
.wrap{max-width:800px;margin:0 auto;}
.top-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:10px;}
.brand-pill{display:inline-flex;align-items:center;gap:8px;background:#fff;border-radius:20px;padding:6px 16px;border:1px solid #eee;font-size:12px;font-weight:600;color:#8C7B80;}
.actions{display:flex;gap:8px;}
.btn{padding:8px 18px;font-size:12px;font-weight:600;font-family:'Montserrat',sans-serif;background:#8C7B80;color:#fff;border:none;border-radius:8px;cursor:pointer;}
.btn:hover{background:#6B5A5F;}
.btn-sec{background:transparent;color:#8C7B80;border:1.5px solid #8C7B80;}
.btn-sec:hover{background:#f3efef;}
.loading{text-align:center;padding:4rem;color:#999;font-size:14px;}
.dots span{display:inline-block;width:6px;height:6px;border-radius:50%;background:#8C7B80;margin:0 2px;animation:dp 1.2s ease-in-out infinite;}
.dots span:nth-child(2){animation-delay:.2s;}.dots span:nth-child(3){animation-delay:.4s;}
@keyframes dp{0%,80%,100%{opacity:.2;transform:scale(.8)}40%{opacity:1;transform:scale(1)}}

/* CV DOCUMENT */
.cv-doc{background:#fff;border-radius:0;box-shadow:0 2px 20px rgba(0,0,0,.08);margin-bottom:2rem;}
.cv-header{background:#8C7B80;padding:36px 40px;display:flex;align-items:center;gap:28px;}
.cv-photo{width:90px;height:90px;border-radius:50%;border:3px solid rgba(255,255,255,.4);object-fit:cover;flex-shrink:0;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;}
.cv-photo-placeholder{width:90px;height:90px;border-radius:50%;border:3px solid rgba(255,255,255,.3);flex-shrink:0;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:700;color:rgba(255,255,255,.8);}
.cv-header-info{flex:1;}
.cv-name{font-size:26px;font-weight:700;color:#fff;line-height:1.2;margin-bottom:4px;}
.cv-title{font-size:13px;font-weight:500;color:rgba(255,255,255,.85);letter-spacing:.04em;margin-bottom:12px;}
.cv-contact{display:flex;flex-wrap:wrap;gap:12px;}
.cv-contact-item{font-size:11px;color:rgba(255,255,255,.8);display:flex;align-items:center;gap:5px;}
.cv-contact-item strong{color:#fff;}

.cv-body{display:grid;grid-template-columns:1fr 2.2fr;min-height:600px;}
.cv-sidebar{background:#f9f8f8;padding:28px 24px;border-right:1px solid #eee;}
.cv-main-col{padding:28px 32px;}

.cv-section{margin-bottom:24px;}
.cv-section-title{font-size:10px;font-weight:700;color:#8C7B80;text-transform:uppercase;letter-spacing:.12em;margin-bottom:10px;padding-bottom:6px;border-bottom:2px solid #8C7B80;}
.cv-section-body{font-size:12px;color:#333;line-height:1.7;}

/* SIDEBAR SECTIONS */
.skill-item{font-size:12px;color:#333;padding:4px 0;border-bottom:0.5px solid #ece8e8;line-height:1.4;}
.skill-item:last-child{border-bottom:none;}
.lang-item{display:flex;justify-content:space-between;font-size:12px;color:#333;padding:4px 0;border-bottom:0.5px solid #ece8e8;}
.lang-level{font-size:11px;color:#8C7B80;font-weight:600;}
.score-item{margin-bottom:10px;}
.score-label{font-size:11px;color:#555;margin-bottom:3px;font-weight:500;}
.score-track{height:5px;background:#e8e4e5;border-radius:3px;overflow:hidden;}
.score-fill{height:5px;border-radius:3px;background:#8C7B80;}
.score-pct{font-size:10px;color:#8C7B80;font-weight:700;margin-top:2px;}
.edu-item{margin-bottom:12px;}
.edu-degree{font-size:12px;font-weight:600;color:#1a1a1a;line-height:1.3;}
.edu-school{font-size:11px;color:#666;margin-top:2px;}
.edu-year{font-size:10px;color:#8C7B80;font-weight:600;margin-top:2px;}
.cert-item{font-size:11px;color:#333;padding:4px 0;border-bottom:0.5px solid #ece8e8;line-height:1.4;}

/* MAIN COL */
.exp-item{margin-bottom:20px;padding-bottom:20px;border-bottom:0.5px solid #f0ece8;}
.exp-item:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0;}
.exp-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px;gap:8px;}
.exp-title{font-size:14px;font-weight:700;color:#1a1a1a;line-height:1.3;}
.exp-dates{font-size:11px;color:#8C7B80;font-weight:600;white-space:nowrap;flex-shrink:0;}
.exp-company{font-size:12px;color:#666;margin-bottom:8px;font-style:italic;}
.exp-context{font-size:11px;color:#888;background:#f9f8f8;border-radius:4px;padding:4px 8px;margin-bottom:8px;line-height:1.4;border-left:2px solid #D4C5C8;}
.exp-bullets{list-style:none;padding:0;}
.exp-bullets li{font-size:12px;color:#333;line-height:1.65;padding:3px 0 3px 14px;position:relative;}
.exp-bullets li::before{content:'';position:absolute;left:0;top:10px;width:5px;height:5px;border-radius:50%;background:#8C7B80;}

.cv-footer{background:#f9f8f8;border-top:1px solid #eee;padding:12px 40px;display:flex;justify-content:space-between;align-items:center;}
.cv-footer-brand{font-size:10px;color:#8C7B80;font-weight:600;}
.cv-footer-note{font-size:10px;color:#aaa;}

/* EDIT MODE */
.edit-overlay{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.5);z-index:999;align-items:center;justify-content:center;padding:1rem;}
.edit-overlay.on{display:flex;}
.edit-box{background:#fff;border-radius:14px;padding:24px;max-width:600px;width:100%;max-height:90vh;overflow-y:auto;}
.edit-box h3{font-size:15px;font-weight:700;margin-bottom:14px;}
.edit-field{margin-bottom:12px;}
.edit-field label{display:block;font-size:10px;font-weight:700;color:#666;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px;}
.edit-field input,.edit-field textarea{width:100%;padding:9px 11px;font-size:13px;font-family:'Montserrat',sans-serif;border:1.5px solid #ddd;border-radius:8px;outline:none;color:#1a1a1a;}
.edit-field input:focus,.edit-field textarea:focus{border-color:#8C7B80;}

@media(max-width:600px){.cv-body{grid-template-columns:1fr;}.cv-header{flex-direction:column;text-align:center;}.cv-contact{justify-content:center;}}
@media print{
  body{background:#fff;padding:0;}
  .top-bar{display:none;}
  .cv-doc{box-shadow:none;border-radius:0;}
  .cv-header{-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  .score-fill{-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  .cv-sidebar{-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  @page{margin:.5cm;size:A4;}
}
</style>
</head>
<body>
<div class="wrap">
  <div class="top-bar">
    <div class="brand-pill">Micaela Jairedin &middot; Career Coach & Recruiter</div>
    <div class="actions">
      <button class="btn btn-sec" onclick="abrirEditor()">Editar CV</button>
      <button class="btn" onclick="window.print()">Descargar PDF</button>
    </div>
  </div>
  <div id="content">
    <div class="loading"><div class="dots"><span></span><span></span><span></span></div><p style="margin-top:12px;">Cargando tu CV...</p></div>
  </div>
</div>

<!-- EDIT MODAL -->
<div class="edit-overlay" id="edit-modal">
  <div class="edit-box">
    <h3>Editar CV</h3>
    <div class="edit-field"><label>Nombre completo</label><input id="e-name" type="text"></div>
    <div class="edit-field"><label>Titular profesional</label><input id="e-title" type="text"></div>
    <div class="edit-field"><label>Email</label><input id="e-email" type="text"></div>
    <div class="edit-field"><label>Telefono</label><input id="e-phone" type="text"></div>
    <div class="edit-field"><label>Ciudad</label><input id="e-city" type="text"></div>
    <div class="edit-field"><label>LinkedIn (URL completa)</label><input id="e-li" type="text"></div>
    <div class="edit-field"><label>Resumen ejecutivo</label><textarea id="e-summary" rows="4"></textarea></div>
    <div class="edit-field"><label>Habilidades (una por linea)</label><textarea id="e-skills" rows="6"></textarea></div>
    <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:8px;">
      <button class="btn btn-sec" onclick="cerrarEditor()">Cancelar</button>
      <button class="btn" onclick="guardarEditor()">Guardar cambios</button>
    </div>
  </div>
</div>

<script>
var SB_URL='https://ddxnrsnjdvtqhxunxnwj.supabase.co';
var SB_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRkeG5yc25qZHZ0cWh4dW54bndqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUxNDk5MzksImV4cCI6MjA5MDcyNTkzOX0.t82X1x-PDgFDGYhKC7YXoRKhga9I8Hjet60QUYvtZLU';

var cvData=null;
var editData={};

function init(){
  var params=new URLSearchParams(window.location.search);
  var email=params.get('email');
  var code=params.get('code');
  if(!email){showError('No se encontro el CV. Contacta con Micaela.');return;}

  fetch(SB_URL+'/rest/v1/cv_publicados?email=eq.'+encodeURIComponent(email)+'&order=created_at.desc&limit=1&select=*',{
    headers:{'apikey':SB_KEY,'Authorization':'Bearer '+SB_KEY}
  }).then(function(r){return r.json();}).then(function(rows){
    if(!rows||!rows.length){showError('Tu CV aun no esta disponible.');return;}
    var row=rows[0];
    if(row.codigo&&code!==row.codigo){
      showCodeForm(email);return;
    }
    cvData=row;
    renderCV(row);
  }).catch(function(){showError('Error al cargar.');});
}

function showError(msg){
  document.getElementById('content').innerHTML='<div class="loading"><p>'+msg+'</p><p style="font-size:12px;color:#ccc;margin-top:8px;">mmicaela.jairedin@gmail.com</p></div>';
}

function showCodeForm(email){
  document.getElementById('content').innerHTML='<div style="background:#fff;border-radius:14px;padding:2rem;text-align:center;max-width:400px;margin:0 auto;">'
    +'<div style="font-size:36px;margin-bottom:14px;">&#128274;</div>'
    +'<h3 style="font-size:16px;font-weight:700;margin-bottom:8px;">Introduce tu codigo de acceso</h3>'
    +'<p style="font-size:13px;color:#666;margin-bottom:16px;">Micaela te lo envio por WhatsApp.</p>'
    +'<div style="display:flex;gap:8px;justify-content:center;">'
    +'<input id="code-inp" type="text" maxlength="6" placeholder="XXXXXX" style="width:130px;padding:10px;font-size:16px;font-family:Montserrat,sans-serif;border:1.5px solid #ddd;border-radius:8px;text-align:center;letter-spacing:.2em;font-weight:600;outline:none;">'
    +'<button onclick="verificarCodigo(\''+email+'\')" style="padding:10px 18px;font-size:13px;font-weight:600;font-family:Montserrat,sans-serif;background:#8C7B80;color:#fff;border:none;border-radius:8px;cursor:pointer;">Acceder</button>'
    +'</div>'
    +'<p id="code-err" style="font-size:12px;color:#c0756e;margin-top:8px;min-height:16px;"></p>'
    +'</div>';
}

function verificarCodigo(email){
  var code=document.getElementById('code-inp').value.trim().toUpperCase();
  fetch(SB_URL+'/rest/v1/cv_publicados?email=eq.'+encodeURIComponent(email)+'&order=created_at.desc&limit=1&select=*',{
    headers:{'apikey':SB_KEY,'Authorization':'Bearer '+SB_KEY}
  }).then(function(r){return r.json();}).then(function(rows){
    if(!rows||!rows.length){document.getElementById('code-err').textContent='CV no disponible.';return;}
    var row=rows[0];
    if(code===row.codigo.toUpperCase()){
      cvData=row;
      window.history.replaceState({},'',window.location.pathname+'?email='+encodeURIComponent(email)+'&code='+code);
      renderCV(row);
    } else {
      document.getElementById('code-err').textContent='Codigo incorrecto.';
    }
  });
}

function parseCVText(text){
  // Parse plain text CV into structured data
  var lines=text.split('\n');
  var data={
    name:'',title:'',email:'',phone:'',city:'',linkedin:'',
    summary:'',skills:[],languages:[],education:[],certifications:[],
    experience:[],scores:null
  };

  // Try to extract name from first non-empty line
  for(var i=0;i<Math.min(5,lines.length);i++){
    if(lines[i].trim()){data.name=lines[i].trim();break;}
  }

  // Extract email
  var emailMatch=text.match(/[\w.-]+@[\w.-]+\.\w+/);
  if(emailMatch) data.email=emailMatch[0];

  // Extract phone
  var phoneMatch=text.match(/\+?[\d\s().-]{9,}/);
  if(phoneMatch) data.phone=phoneMatch[0].trim();

  // Extract LinkedIn
  var liMatch=text.match(/linkedin\.com\/in\/[\w-]+/i);
  if(liMatch) data.linkedin='https://'+liMatch[0];

  // Store raw text for display
  data.rawText=text;
  return data;
}

function renderCV(row){
  var contenido=row.contenido||'';
  var parsed=parseCVText(contenido);
  editData=parsed;

  // Get ini for placeholder photo
  var ini=parsed.name.split(' ').map(function(w){return w[0]||'';}).join('').slice(0,2).toUpperCase()||'CV';

  var html='<div class="cv-doc">';

  // HEADER
  html+='<div class="cv-header">'
    +'<div class="cv-photo-placeholder">'+ini+'</div>'
    +'<div class="cv-header-info">'
      +'<div class="cv-name" id="cv-name">'+(parsed.name||'Nombre del candidato')+'</div>'
      +'<div class="cv-title" id="cv-title">'+extractTitle(contenido)+'</div>'
      +'<div class="cv-contact">'
        +(parsed.email?'<div class="cv-contact-item"><strong>'+parsed.email+'</strong></div>':'')
        +(parsed.phone?'<div class="cv-contact-item">'+parsed.phone+'</div>':'')
        +(parsed.linkedin?'<div class="cv-contact-item">'+parsed.linkedin+'</div>':'')
      +'</div>'
    +'</div>'
  +'</div>';

  // BODY
  html+='<div class="cv-body">';

  // SIDEBAR
  html+='<div class="cv-sidebar">';

  // Skills
  var skills=extractSection(contenido,'HABILIDADES');
  if(skills){
    html+='<div class="cv-section"><div class="cv-section-title">Habilidades</div>'
      +skills.split('\n').filter(function(l){return l.trim()&&l.trim()!='--';}).map(function(l){
        return '<div class="skill-item">'+l.trim().replace(/^[·\-\*]\s*/,'')+'</div>';
      }).join('')+'</div>';
  }

  // Languages
  var langs=extractSection(contenido,'IDIOMAS');
  if(langs){
    html+='<div class="cv-section"><div class="cv-section-title">Idiomas</div>'
      +langs.split('\n').filter(function(l){return l.trim()&&l.trim()!='--';}).map(function(l){
        var parts=l.split(':');
        if(parts.length>1){
          return '<div class="lang-item"><span>'+parts[0].trim()+'</span><span class="lang-level">'+parts[1].trim()+'</span></div>';
        }
        return '<div class="lang-item">'+l.trim()+'</div>';
      }).join('')+'</div>';
  }

  // Education
  var edu=extractSection(contenido,'FORMACION');
  if(!edu) edu=extractSection(contenido,'FORMACI');
  if(edu){
    html+='<div class="cv-section"><div class="cv-section-title">Formacion</div>'
      +edu.split('\n').filter(function(l){return l.trim()&&l.trim()!='--';}).map(function(l){
        return '<div class="edu-item"><div class="edu-degree">'+l.trim()+'</div></div>';
      }).join('')+'</div>';
  }

  // Certifications
  var certs=extractSection(contenido,'CERTIFICACIONES');
  if(!certs) certs=extractSection(contenido,'CERTIFICACI');
  if(certs){
    html+='<div class="cv-section"><div class="cv-section-title">Certificaciones</div>'
      +certs.split('\n').filter(function(l){return l.trim()&&l.trim()!='--';}).map(function(l){
        return '<div class="cert-item">'+l.trim().replace(/^[·\-\*]\s*/,'')+'</div>';
      }).join('')+'</div>';
  }

  html+='</div>'; // end sidebar

  // MAIN COL
  html+='<div class="cv-main-col">';

  // Summary
  var summary=extractSection(contenido,'RESUMEN');
  if(!summary) summary=extractSection(contenido,'EJECUTIVO');
  if(summary){
    html+='<div class="cv-section"><div class="cv-section-title">Resumen ejecutivo</div>'
      +'<div class="cv-section-body">'+summary.trim()+'</div>'
      +'</div>';
  }

  // Experience
  html+='<div class="cv-section"><div class="cv-section-title">Experiencia profesional</div>';
  var expSection=extractSection(contenido,'EXPERIENCIA');
  if(expSection){
    // Split by company blocks (lines with -- or dates)
    var expBlocks=splitExperience(expSection);
    expBlocks.forEach(function(block){
      html+=renderExpBlock(block);
    });
  }
  html+='</div>';

  html+='</div>'; // end main col
  html+='</div>'; // end body

  // FOOTER
  html+='<div class="cv-footer">'
    +'<div class="cv-footer-brand">Micaela Jairedin &middot; Career Coach & Recruiter</div>'
    +'<div class="cv-footer-note">CV optimizado &middot; Confidencial</div>'
    +'</div>';

  html+='</div>'; // end cv-doc

  document.getElementById('content').innerHTML=html;
}

function extractTitle(text){
  var lines=text.split('\n');
  // Look for the line after the name that has keywords
  for(var i=1;i<Math.min(8,lines.length);i++){
    var l=lines[i].trim();
    if(l&&l.length>10&&l.length<120&&!l.includes('@')&&!l.match(/^\+?\d/)){
      return l;
    }
  }
  return '';
}

function extractSection(text,keyword){
  var upper=text.toUpperCase();
  var idx=upper.indexOf(keyword);
  if(idx===-1) return '';
  // Find next section (line with all caps and length > 5)
  var after=text.substring(idx);
  var lines=after.split('\n');
  var result=[];
  var started=false;
  for(var i=0;i<lines.length;i++){
    if(i===0){started=true;continue;}
    var l=lines[i];
    var upper_l=l.trim().toUpperCase();
    // Stop if we hit another section header
    if(i>0&&upper_l===l.trim()&&upper_l.length>4&&upper_l.length<50&&!upper_l.includes('@')&&!upper_l.match(/^[·\-\*]/)&&upper_l.match(/^[A-Z\s]+$/)){
      if(result.length>0) break;
    }
    result.push(l);
  }
  return result.join('\n').trim();
}

function splitExperience(text){
  var lines=text.split('\n');
  var blocks=[];
  var current=[];
  lines.forEach(function(l){
    // New block starts with a line that has a date pattern or is a title
    if(l.trim()&&(l.match(/\d{4}/) && l.length<120 && current.length>2)){
      if(current.length) blocks.push(current.join('\n'));
      current=[l];
    } else {
      current.push(l);
    }
  });
  if(current.length) blocks.push(current.join('\n'));
  return blocks.filter(function(b){return b.trim().length>10;});
}

function renderExpBlock(block){
  var lines=block.split('\n').filter(function(l){return l.trim();});
  if(!lines.length) return '';

  var title=lines[0];
  var dates='';
  var company='';
  var context='';
  var bullets=[];

  // Try to extract dates from title line
  var dateMatch=title.match(/(\d{4})\s*[–\-]\s*(\w+|\d{4})/);
  if(dateMatch){
    dates=dateMatch[0];
    title=title.replace(dates,'').replace(/[|·]/g,'').trim();
  }

  for(var i=1;i<lines.length;i++){
    var l=lines[i].trim();
    if(!l) continue;
    if(i===1&&!l.startsWith('-')&&!l.startsWith('·')){
      company=l;
    } else if(l.startsWith('*')&&l.includes('Contexto')||l.startsWith('*')&&l.includes('Nota')){
      context=l.replace(/^\*+/,'').trim();
    } else if(l.startsWith('-')||l.startsWith('·')||l.startsWith('•')){
      bullets.push(l.replace(/^[-·•]\s*/,''));
    }
  }

  var html='<div class="exp-item">'
    +'<div class="exp-header">'
      +'<div class="exp-title">'+title+'</div>'
      +(dates?'<div class="exp-dates">'+dates+'</div>':'')
    +'</div>'
    +(company?'<div class="exp-company">'+company+'</div>':'')
    +(context?'<div class="exp-context">'+context+'</div>':'')
    +(bullets.length?'<ul class="exp-bullets">'+bullets.map(function(b){return '<li>'+b+'</li>';}).join('')+'</ul>':'')
    +'</div>';
  return html;
}

function abrirEditor(){
  if(!cvData) return;
  document.getElementById('e-name').value=document.getElementById('cv-name')?document.getElementById('cv-name').textContent:'';
  document.getElementById('e-title').value=document.getElementById('cv-title')?document.getElementById('cv-title').textContent:'';
  document.getElementById('e-email').value=editData.email||'';
  document.getElementById('e-phone').value=editData.phone||'';
  document.getElementById('e-city').value=editData.city||'';
  document.getElementById('e-li').value=editData.linkedin||'';
  document.getElementById('e-summary').value=extractSection(cvData.contenido||'','RESUMEN')||'';
  document.getElementById('e-skills').value=(extractSection(cvData.contenido||'','HABILIDADES')||'').split('\n').filter(function(l){return l.trim();}).join('\n');
  document.getElementById('edit-modal').classList.add('on');
}

function cerrarEditor(){
  document.getElementById('edit-modal').classList.remove('on');
}

function guardarEditor(){
  // Update displayed name and title
  if(document.getElementById('cv-name')) document.getElementById('cv-name').textContent=document.getElementById('e-name').value;
  if(document.getElementById('cv-title')) document.getElementById('cv-title').textContent=document.getElementById('e-title').value;
